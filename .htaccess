# ═══════════════════════════════════════════
# .htaccess - hayaxxdev-bit Portfolio
# Apache Configuration
# ═══════════════════════════════════════════

# ═══════════════ ENABLE REWRITE ENGINE ═══════════════
RewriteEngine On

# ═══════════════ CACHING ═══════════════
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Images - 1 year
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/ico "access plus 1 year"
  
  # CSS, JS - 1 month
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  
  # Fonts - 1 year
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  
  # HTML - 1 hour
  ExpiresByType text/html "access plus 1 hour"
  
  # JSON - 1 hour
  ExpiresByType application/json "access plus 1 hour"
  
  # Web Manifest
  ExpiresByType application/manifest+json "access plus 1 month"
</IfModule>

# ═══════════════ CACHE CONTROL HEADERS ═══════════════
<IfModule mod_headers.c>
  # Images - immutable
  <FilesMatch "\.(webp|jpe?g|png|gif|svg|ico|svgz)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  
  # CSS & JS
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000, must-revalidate"
  </FilesMatch>
  
  # Fonts - immutable
  <FilesMatch "\.(woff2?|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  
  # HTML - no cache
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
  
  # Security Headers
  <IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  </IfModule>
</IfModule>

# ═══════════════ GZIP COMPRESSION ═══════════════
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/manifest+json
  AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# ═══════════════ ERROR PAGES ═══════════════
ErrorDocument 400 /error.html?code=400
ErrorDocument 401 /error.html?code=401
ErrorDocument 403 /error.html?code=403
ErrorDocument 404 /404.html
ErrorDocument 405 /error.html?code=405
ErrorDocument 408 /error.html?code=408
ErrorDocument 500 /error.html?code=500
ErrorDocument 502 /error.html?code=502
ErrorDocument 503 /error.html?code=503
ErrorDocument 504 /error.html?code=504

# ═══════════════ SECURITY ═══════════════

# Prevent directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "\.(env|git|htpasswd|ini|phps|fla|psd|log|sh|md|yml|yaml)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Protect hidden files
<FilesMatch "^\.">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Protect .htaccess itself
<Files ".htaccess">
    Order Allow,Deny
    Deny from all
</Files>

# ═══════════════ REWRITE RULES ═══════════════

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Force WWW (uncomment jika perlu)
# RewriteCond %{HTTP_HOST} !^www\. [NC]
# RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [R=301,L]

# Remove trailing slashes
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# Block access to admin paths
RewriteCond %{REQUEST_URI} ^/admin.*$
RewriteRule ^(.*)$ /404.html [L,R=404]

# Block access to wp-* paths (mencegah bot WordPress)
RewriteCond %{REQUEST_URI} ^/wp-.*$
RewriteRule ^(.*)$ /404.html [L,R=404]

# Block common exploit attempts
RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2})
RewriteRule ^(.*)$ /404.html [L,R=404]