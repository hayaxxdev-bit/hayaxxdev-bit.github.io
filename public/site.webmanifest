{
  "name": "hayaxxdev-bit Portfolio",
  "short_name": "hayaxxdev",
  "description": "Portfolio & Game Developer - Fullstack Developer dengan estetika manga modern",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#050308",
  "theme_color": "#050308",
  "orientation": "any",
  "scope": "/",
  "categories": ["portfolio", "developer", "gamedev", "design", "web"],
  "lang": "id-ID",
  "dir": "ltr",
  "prefer_related_applications": false,
  "related_applications": [],
  "shortcuts": [
    {
      "name": "Beranda",
      "short_name": "Home",
      "description": "Kembali ke halaman utama",
      "url": "/",
      "icons": [
        {
          "src": "/icons/shortcut-home-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Karya",
      "short_name": "Projects",
      "description": "Lihat semua karya dan proyek",
      "url": "/?route=project",
      "icons": [
        {
          "src": "/icons/shortcut-projects-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
