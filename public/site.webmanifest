        {
          "src": "/icons/shortcut-about-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Kontak",
      "short_name": "Contact",
      "description": "Hubungi hayaxxdev",
