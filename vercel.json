{
  "version": 2,
  "name": "hayaxxdev-portfolio",
  "buildCommand": null,
  "outputDirectory": "public",
  "installCommand": null,
  "framework": null,
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "rewrites": [
    {
      "source": "/api/repos",
      "destination": "/api/repos"
    },
    {
      "source": "/api/github",
      "destination": "/api/github"
    }
  ],
  "redirects": [
    {
      "source": "/github",
      "destination": "https://github.com/hayaxxdev-bit",
      "permanent": true
    },
    {
      "source": "/linkedin",
      "destination": "https://linkedin.com/in/hayaxxdev",
      "permanent": true
    },
    {
      "source": "/repo/:path*",
      "destination": "https://github.com/hayaxxdev-bit/:path*",
      "permanent": true
    },
    {
      "source": "/old-portfolio",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/v1",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/v2",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/v3",
      "destination": "/",
      "permanent": true
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS, POST" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    },
    {
      "source": "/(.*)\\.(webp|jpe?g|png|gif|svg|ico)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.(woff2?|ttf|otf|eot)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    }
  ]
}